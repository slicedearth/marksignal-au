---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "MarkSignal AU | Signals in public trade mark filings",
  description = "Evidence-linked filing patterns from selected Australian trade mark records.",
  image = "social-card.svg"
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(`${base}${image}`, Astro.site);
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#071a24" />
    <meta name="color-scheme" content="light" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; connect-src 'none'; font-src 'self'; form-action 'self'; frame-src 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'; upgrade-insecure-requests"
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="MarkSignal AU filing signals" href={`${base}feed.xml`} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={base} aria-label="MarkSignal AU home">
        <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
          <circle cx="20" cy="20" r="4"></circle>
          <path d="M8 20a12 12 0 0 1 24 0"></path>
          <path d="M3 20a17 17 0 0 1 34 0"></path>
        </svg>
        <span>MarkSignal <b>AU</b></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={`${base}#signals`}>Signals</a>
        <a href={`${base}#applicants`}>Applicants</a>
        <a href={`${base}data/`}>Data</a>
        <a href={`${base}methodology/`}>Methodology</a>
        <a class="nav-feed" href={`${base}feed.xml`}>RSS</a>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-branding">
        <a class="brand" href={base}>
          <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
            <circle cx="20" cy="20" r="4"></circle>
            <path d="M8 20a12 12 0 0 1 24 0"></path>
            <path d="M3 20a17 17 0 0 1 34 0"></path>
          </svg>
          <span>MarkSignal AU</span>
        </a>
        <p>Independent, evidence-first analysis of public trade mark records.</p>
      </div>
      <div class="footer-links">
        <a href={`${base}methodology/`}>Methodology and limitations</a>
        <a href={`${base}data/`}>Downloads and attribution</a>
        <a href="https://github.com/slicedearth/marksignal-au" rel="noreferrer">Source code ↗</a>
      </div>
      <p class="fine-print">
        Not affiliated with or endorsed by the Australian Government. Selected IP RAPID data is
        attributed to IP Australia under{" "}
        <a href="https://creativecommons.org/licenses/by/4.0/" rel="noreferrer">CC BY 4.0</a>.
      </p>
    </footer>
  </body>
</html>
