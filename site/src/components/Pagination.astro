---
import { getPaginationItems } from "../lib/pagination";

interface Props {
  currentPage: number;
  totalPages: number;
  position: "top" | "bottom";
  kind: "signals" | "applicant-filings" | "trademark-events";
  entityKey?: string;
  anchorId: string;
  label: string;
  pageHref: (page: number) => string;
}

const {
  currentPage,
  totalPages,
  position,
  kind,
  entityKey,
  anchorId,
  label,
  pageHref
} = Astro.props;
const pages = getPaginationItems(currentPage, totalPages);
---

<nav
  id={position === "top" ? anchorId : undefined}
  class:list={["signal-pagination", `signal-pagination--${position}`]}
  data-client-pagination
  data-pagination-kind={kind}
  data-pagination-key={entityKey}
  data-pagination-position={position}
  aria-label={`${label} pages ${position === "top" ? "above" : "below"} results`}
>
  {currentPage > 1
    ? (
      <a
        class="signal-pagination__step"
        href={pageHref(currentPage - 1)}
        rel="prev"
      >
        <span aria-hidden="true">←</span>
        <span class="signal-pagination__step-label">Previous</span>
      </a>
    )
    : (
      <span class="signal-pagination__step" aria-disabled="true">
        <span aria-hidden="true">←</span>
        <span class="signal-pagination__step-label">Previous</span>
      </span>
    )}

  <ol class="signal-pagination__pages">
    {pages.map((page) => page === null
      ? <li class="signal-pagination__ellipsis" aria-hidden="true">…</li>
      : (
        <li class:list={{ "is-current": page === currentPage }}>
          {page === currentPage
            ? <span aria-current="page"><span class="visually-hidden">Page </span>{page}</span>
            : <a href={pageHref(page)} aria-label={`Go to page ${page}`}>{page}</a>}
        </li>
      ))}
  </ol>

  {currentPage < totalPages
    ? (
      <a
        class="signal-pagination__step"
        href={pageHref(currentPage + 1)}
        rel="next"
      >
        <span class="signal-pagination__step-label">Next</span>
        <span aria-hidden="true">→</span>
      </a>
    )
    : (
      <span class="signal-pagination__step" aria-disabled="true">
        <span class="signal-pagination__step-label">Next</span>
        <span aria-hidden="true">→</span>
      </span>
    )}
</nav>
