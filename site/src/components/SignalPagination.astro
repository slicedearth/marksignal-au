---
import Pagination from "./Pagination.astro";

interface Props {
  currentPage: number;
  totalPages: number;
  position: "top" | "bottom";
}

const { currentPage, totalPages, position } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageHref = (page: number) => page === 1
  ? `${base}#signal-results`
  : `${base}signals/${page}/#signal-results`;
---

<Pagination
  currentPage={currentPage}
  totalPages={totalPages}
  position={position}
  kind="signals"
  anchorId="signal-results"
  label="Signal feed"
  pageHref={pageHref}
/>
