---
import { label } from "../lib/format";
import type { FilingSignal } from "../types";
import SignalCard from "./SignalCard.astro";
import SignalPagination from "./SignalPagination.astro";

interface Props {
  signals: FilingSignal[];
  totalSignals: number;
  currentPage: number;
  totalPages: number;
}

const { signals, totalSignals, currentPage, totalPages } = Astro.props;
const base = import.meta.env.BASE_URL;
const applicants = [...new Map(
  signals.map((signal) => [signal.applicant_id, signal.applicant_name] as const)
).entries()].sort((left, right) => left[1].localeCompare(right[1], "en-AU"));
const reasonTypes = [...new Set(
  signals.flatMap((signal) => signal.reasons.map((reason) => reason.type))
)].sort();
---

<section class="content-section signals-section" id="signals" data-current-page={currentPage}>
  <div class="section-heading">
    <div>
      <p class="eyebrow"><span></span> Signal feed</p>
      <h2>Why was this surfaced?</h2>
      <p>Each point is tied to a visible calculation and a downloadable evidence record.</p>
    </div>
    <a class="download-link" href={`${base}data/signals.csv`} download>Download all CSV ↓</a>
  </div>

  <form class="filters" data-filters aria-label="Filter filing signals on this page">
    <label class="search-field">
      <span>Search</span>
      <div><span aria-hidden="true">⌕</span><input type="search" name="query" placeholder="Mark, applicant, number" autocomplete="off" /></div>
    </label>
    <label>
      <span>Applicant</span>
      <select name="applicant">
        <option value="">All applicants</option>
        {applicants.map(([applicantId, applicantName]) => (
          <option value={applicantId}>{applicantName}</option>
        ))}
      </select>
    </label>
    <label>
      <span>Reason</span>
      <select name="reason">
        <option value="">All reasons</option>
        {reasonTypes.map((reason) => <option value={reason}>{label(reason)}</option>)}
      </select>
    </label>
    <label>
      <span>Minimum score</span>
      <select name="score">
        <option value="0">Any score</option>
        <option value="40">40+</option>
        <option value="60">60+</option>
        <option value="80">80+</option>
      </select>
    </label>
    <button class="reset-button" type="reset">Clear</button>
  </form>

  <div class="result-line">
    <p aria-live="polite">
      <strong data-result-count>{signals.length}</strong> matching signals on page {currentPage} of
      {` ${totalPages}`}. {totalSignals} published signals in total
    </p>
    <button class="text-button" type="button" data-download-filtered>Download filtered page CSV</button>
  </div>
  <p class="page-filter-note">Filters and the filtered CSV apply to this page.</p>

  <SignalPagination currentPage={currentPage} totalPages={totalPages} position="top" />

  <div class="signal-list" data-signal-list>
    {signals.map((signal) => <SignalCard signal={signal} />)}
  </div>
  <div class="empty-state" data-empty hidden>
    <span aria-hidden="true">○</span><h3>No signals match those filters</h3><p>Try a broader search or clear the filters.</p>
  </div>

  <SignalPagination currentPage={currentPage} totalPages={totalPages} position="bottom" />
</section>

<script is:inline type="module" src={`${base}scripts/home.js`}></script>
