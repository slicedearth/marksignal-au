---
import TrademarkRecord from "../../components/TrademarkRecord.astro";
import rawDashboard from "../../data/dashboard.json";
import type { Dashboard, FilingSignal, ObservedChange, Trademark } from "../../types";

export function getStaticPaths() {
  const data = rawDashboard as unknown as Dashboard;
  return data.trademarks.map((trademark) => ({
    params: { number: trademark.trademark_number },
    props: {
      trademark,
      signals: data.signals.filter((item) => item.trademark_number === trademark.trademark_number),
      changes: data.changes.filter((item) => item.trademark_number === trademark.trademark_number),
      isDemo: data.is_demo,
      disclaimer: data.disclaimer
    }
  }));
}

interface Props {
  trademark: Trademark;
  signals: FilingSignal[];
  changes: ObservedChange[];
  isDemo: boolean;
  disclaimer: string;
}

const { trademark, signals, changes, isDemo, disclaimer } = Astro.props;
---

<TrademarkRecord
  trademark={trademark}
  signals={signals}
  changes={changes}
  isDemo={isDemo}
  disclaimer={disclaimer}
  currentPage={1}
/>
