---
import SignalFeed from "../../components/SignalFeed.astro";
import { getSignalPage, getSignalPageCount } from "../../lib/pagination";
import BaseLayout from "../../layouts/BaseLayout.astro";
import rawDashboard from "../../data/dashboard.json";
import type { Dashboard } from "../../types";

interface Props {
  page: number;
}

export function getStaticPaths() {
  const dashboard = rawDashboard as unknown as Dashboard;
  const totalPages = getSignalPageCount(dashboard.signals.length);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return { params: { page: String(page) }, props: { page } };
  });
}

const dashboard = rawDashboard as unknown as Dashboard;
const { page } = Astro.props;
const totalPages = getSignalPageCount(dashboard.signals.length);
const pageSignals = getSignalPage(dashboard.signals, page);
---

<BaseLayout
  title={`Filing signals, page ${page} | MarkSignal AU`}
  description={`Page ${page} of evidence-linked signals from selected Australian trade mark filings.`}
>
  <header class="page-hero signal-page-hero">
    <div>
      <p class="eyebrow"><span></span> Signal feed</p>
      <h1>Published signals,<br /><em>page {page}.</em></h1>
      <p>
        Browse every published signal across {totalPages} static pages. Filters operate on the
        current page, while the complete CSV remains available for dataset-wide analysis.
      </p>
    </div>
    <dl class="profile-metrics">
      <div><dt>Current page</dt><dd>{page}</dd></div>
      <div><dt>Signals here</dt><dd>{pageSignals.length}</dd></div>
      <div><dt>Total pages</dt><dd>{totalPages}</dd></div>
      <div><dt>Total signals</dt><dd>{dashboard.signals.length}</dd></div>
    </dl>
  </header>

  <SignalFeed
    signals={pageSignals}
    totalSignals={dashboard.signals.length}
    currentPage={page}
    totalPages={totalPages}
  />
</BaseLayout>
